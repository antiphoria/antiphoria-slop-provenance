# Slop Orchestrator environment template.
# Copy this file to .env and fill in your values. Never commit .env.

# Required for generation.
GOOGLE_API_KEY=replace-with-your-google-api-key
GENERATOR_MODEL_ID=gemini-2.5-flash

# Optional quota-safe dummy mode for local pipeline tests.
# When true, generation is local and deterministic (no Google API call).
GENERATOR_DUMMY_MODE=false
GENERATOR_DUMMY_DELAY_SEC=1.0

# Required for ML-DSA signing and verification.
# Use absolute paths or paths relative to the repository root.
PQC_PRIVATE_KEY_PATH=./keys/private.key
OQS_PUBLIC_KEY_PATH=./keys/public.key

# Optional signing-key identity metadata.
SIGNER_FINGERPRINT=optional-fingerprint
SIGNING_KEY_VERSION=v1

# Optional ledger commit author override.
LEDGER_AUTHOR_NAME=Slop Orchestrator
LEDGER_AUTHOR_EMAIL=bot@antiphoria.local

# Optional transport/runtime values.
ORCHESTRATOR_TRANSPORT=local
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Optional shared DB path for local and worker parity.
# If unset, each process uses ./state.db in its own working directory.
STATE_DB_PATH=./state.db

# Optional Kafka worker tuning.
KAFKA_METRICS_DIR=.metrics
KAFKA_MAX_RETRIES=3
KAFKA_METRICS_FLUSH_EVERY=100
LOG_LEVEL=INFO
LEDGER_REPO_PATH=../antiphoria-archive

# Optional transparency and RFC3161 timestamp services.
TRANSPARENCY_LOG_PUBLISH_URL=https://example.org/transparency/append
RFC3161_TSA_URL=https://freetsa.org/tsr
RFC3161_CA_CERT_PATH=./keys/tsa-ca.pem
RFC3161_TSA_UNTRUSTED_CERT_PATH=./keys/tsa.crt

# Optional OpenSSL overrides (useful on Windows/conda layouts).
# OPENSSL_BIN=openssl
# OPENSSL_CONF=C:/path/to/openssl.cnf

# Optional C2PA dual-write mode.
ENABLE_C2PA=false
# C2PA sidecar provider mode:
# - mvp: deterministic JSON sidecar (legacy compatibility)
# - sdk: validator-grade binary sidecar via c2pa-python
C2PA_MODE=mvp
# Required when C2PA_MODE=sdk.
C2PA_SIGN_CERT_CHAIN_PATH=./keys/c2pa-cert-chain.pem
C2PA_PRIVATE_KEY_PATH=./keys/c2pa-private-key.pem
# Optional C2PA signer tuning.
C2PA_SIGNING_ALG=ES256
C2PA_TSA_URL=
# Optional format override for SDK sign/verify (defaults to content type).
C2PA_SDK_ASSET_FORMAT=

# Optional custom liboqs install path.
# OQS_INSTALL_PATH=/path/to/liboqs
