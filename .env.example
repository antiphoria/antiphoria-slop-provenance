# Slop Orchestrator – Environment Template
# Copy this file to .env and fill in your values. Never commit .env to version control.

# Required for generation
GOOGLE_API_KEY=your-google-api-key-here

# Post-quantum signing keys (ML-DSA). Never commit private keys.
# Use absolute paths or paths relative to project root.
PQC_PRIVATE_KEY_PATH=./keys/private.pem
OQS_PUBLIC_KEY_PATH=./keys/public.pem

# Optional: explicit signer fingerprint for key registry
SIGNER_FINGERPRINT=optional-fingerprint

# Transparency log and RFC3161 TSA (optional but recommended)
TRANSPARENCY_LOG_PUBLISH_URL=https://example.org/transparency/append
RFC3161_TSA_URL=https://freetsa.org/tsr
RFC3161_CA_CERT_PATH=./keys/tsa-ca.pem

# Key version for rotation tracking
SIGNING_KEY_VERSION=v1

# Transport and Kafka
ORCHESTRATOR_TRANSPORT=local
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Optional: C2PA manifest generation
ENABLE_C2PA=false

# Optional: liboqs custom install path (use generic path, not workstation-specific)
# OQS_INSTALL_PATH=/path/to/liboqs

# Optional: Ledger commit author (avoids burning personal git identity into public ledger)
# LEDGER_AUTHOR_NAME=Slop Orchestrator
# LEDGER_AUTHOR_EMAIL=bot@antinomie.local
