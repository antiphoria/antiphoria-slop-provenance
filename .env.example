# Slop Orchestrator environment template.
# Copy to .env and fill in values. Never commit .env.

# --- Required for generation (unless dummy mode) ---
GOOGLE_API_KEY=replace-with-your-google-api-key
GENERATOR_MODEL_ID=gemini-2.5-flash

# --- Optional: dummy mode (no Google API, quota-free) ---
GENERATOR_DUMMY_MODE=false
GENERATOR_DUMMY_DELAY_SEC=1.0

# --- Private key paths (injected by run-secure launcher) ---
# Do NOT add PQC_PRIVATE_KEY_PATH or C2PA_PRIVATE_KEY_PATH here when using
# run-secure.ps1 / run-secure.sh. For dev with keys on disk, set them manually.
# Split vault: private keys on encrypted drive (e.g. K:\), public keys in repo.

# --- Required for ML-DSA signing (use PQC_* or OQS_* variants) ---
# PQC_PRIVATE_KEY_PATH=K:\private.key
OQS_PUBLIC_KEY_PATH=./keys/public.key

# --- Ed25519 (classical hybrid alongside ML-DSA) ---
# Private: copy to vault at K:\ed25519_private.pem (run-secure injects when present)
ED25519_PUBLIC_KEY_PATH=./keys/ed25519_public.pem

# --- Optional: custom liboqs install (e.g. Windows/conda) ---
# OQS_INSTALL_PATH=C:/path/to/liboqs

# --- Optional signing identity ---
SIGNER_FINGERPRINT=
SIGNING_KEY_VERSION=v1

# --- Registration ceremony (human-only) ---
# Capture machine ID hash (SHA-256 of MAC) in provenance. Default: false.
# CAPTURE_MACHINE_ID=false

# --- Ledger commit author ---
LEDGER_AUTHOR_NAME=Slop Orchestrator
LEDGER_AUTHOR_EMAIL=bot@antiphoria.local

# --- Runtime ---
# Orchestrator state dir (cache only; never in Archive). All SQLite DBs live here.
# Local: ./.orchestrator-state. Omit to use ./.orchestrator-state
ORCHESTRATOR_STATE_DIR=./.orchestrator-state
# Override specific paths (optional; default derived from ORCHESTRATOR_STATE_DIR)
# ARTIFACT_DB_PATH={ORCHESTRATOR_STATE_DIR}/artifacts.db
LOG_LEVEL=INFO
# Archive repo path. Used by CLI as default for --repo-path.
LEDGER_REPO_PATH=../antiphoria-archive

# --- OTS queue (in Archive repo) ---
# Branch for .provenance/ots-queue.jsonl. Omit to use refs/heads/main.
# OTS_QUEUE_REF=refs/heads/main

# --- Transparency / remote anchor (advanced) ---
# TRANSPARENCY_LOG_PUBLISH_URL=https://<project>.supabase.co/rest/v1/transparency_log
# SUPABASE_SERVICE_KEY=   (preferred for write; required when publish URL is set)
# SUPABASE_ANON_KEY=      (alternative to service key)

# --- RFC3161 timestamping ---
RFC3161_TSA_URL=http://timestamp.digicert.com
RFC3161_CA_CERT_PATH=./keys/tsa-ca.pem
RFC3161_TSA_UNTRUSTED_CERT_PATH=./keys/tsa.crt

# --- Optional OpenSSL overrides (e.g. Windows) ---
# OPENSSL_BIN=openssl
# OPENSSL_CONF=C:/path/to/openssl.cnf

# --- OpenTimestamps Bitcoin anchoring (optional) ---
ENABLE_OTS_FORGE=false
# OTS_BIN overrides bundled bin/ots[.exe]. Omit to use bundled or system PATH.
# OTS_BIN=ots
OTS_FURNACE_INTERVAL_SEC=3600

# --- C2PA dual-write (advanced) ---
ENABLE_C2PA=false
# mvp: deterministic JSON sidecar | sdk: binary sidecar + XML bridge
# C2PA_MODE=mvp
# Required when C2PA_MODE=sdk (cert chain in repo; leaf key in vault):
# C2PA_SIGN_CERT_CHAIN_PATH=./keys/c2pa-cert-chain.pem
# C2PA_PRIVATE_KEY_PATH=K:\c2pa-leaf.key.pem
# C2PA_SIGNING_ALG=ES256
# C2PA_TSA_URL=           (optional; falls back to RFC3161_TSA_URL)
# C2PA_SDK_ASSET_FORMAT=image/jpeg